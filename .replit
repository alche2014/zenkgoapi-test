modules = ["nodejs-24", "python-3.12"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = ["sh", "-c", "cd artifacts/zenko-api && pip install -r requirements.txt && python manage.py migrate --no-input"]
run = ["sh", "-c", "cd artifacts/zenko-api && gunicorn zenko.wsgi:application --bind 0.0.0.0:8000 --workers 2"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Zenko Django API"

[[workflows.workflow]]
name = "Zenko Django API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash artifacts/zenko-api/start.sh"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
