          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"member@zenko.com\",\n  \"role\": \"team_member\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/members/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "organizations", "{{org_id}}", "members", ""]
