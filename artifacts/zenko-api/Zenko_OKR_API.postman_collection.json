            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"title\": \"Monthly Recurring Revenue\",\n    \"metric_label\": \"MRR in USD\",\n    \"type\": \"currency\",\n    \"start_value\": 100000,\n    \"target_value\": 130000,\n    \"current_value\": 100000,\n    \"unit\": \"USD\",\n    \"owner_id\": \"{{user_id}}\",\n    \"due_date\": \"2026-09-30\",\n    \"weightage\": 60\n  },\n  {\n    \"title\": \"New Enterprise Customers\",\n    \"metric_label\": \"Enterprise accounts signed\",\n    \"type\": \"numeric\",\n    \"start_value\": 0,\n    \"target_value\": 10,\n    \"current_value\": 0,\n    \"unit\": \"accounts\",\n    \"owner_id\": \"{{user_id}}\",\n    \"due_date\": \"2026-09-30\",\n    \"weightage\": 40\n  }\n]"
