    {
      "name": "Negative & RBAC Tests",
      "description": "Requests that verify the API correctly enforces its rules by returning error status codes.\n\n**Run order:**\n1. Register Second User — creates a `team_member` and captures `{{member_token}}`\n2. Add Second User to Org as Team Member — so the user is a known member\n3. Create KR — Invalid Weightage — verifies 400 on bad weightage\n4. Submit Without KRs — verifies 400 when KR total ≠ 100%\n5. Approve Objective as Team Member — verifies 403 for insufficient role\n\n**Prerequisites:** Complete the main happy-path flow first (Register → Create Org → Create Objective).",
      "item": [
        {
          "name": "Register Second User (team_member)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('member_token', body.token);",
                  "    console.log('member_token set for RBAC tests');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"member@zenko.com\",\n  \"username\": \"member1\",\n  \"first_name\": \"Team\",\n  \"last_name\": \"Member\",\n  \"password\": \"Member@1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "auth", "register", ""]
            },
            "description": "Registers a second user who will be added to the org as a `team_member`. Their token is saved to `{{member_token}}` for use in RBAC tests."
