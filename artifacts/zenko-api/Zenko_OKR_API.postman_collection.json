      ]
    },
    {
      "name": "Objectives",
      "description": "OKR Objectives with a full lifecycle state machine.\n\n**Lifecycle:** `draft` → `pending_approval` → `approved` / `rejected` → `archived`\n\n- Org admins skip the approval queue — their objectives are set to `approved` immediately on creation.\n- Team members create `draft` objectives and must call **Submit** before an org admin or team lead can approve.",
      "item": [
        {
          "name": "Create Objective",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('obj_id', body.id);",
                  "    console.log('obj_id set:', body.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Increase ARR by 30%\",\n  \"description\": \"Grow annual recurring revenue by expanding enterprise accounts and reducing churn.\",\n  \"owner_id\": 1,\n  \"priority\": \"high\",\n  \"due_date\": \"2026-09-30\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/objectives/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "organizations", "{{org_id}}", "objectives", ""]
            },
            "description": "Creates a new Objective.\n\n- **Org admins** → status is `approved` immediately.\n- **Other roles** → status is `draft`; must be submitted for approval.\n\nThe `quarter` field is auto-computed from `due_date`. The new objective's `id` is saved to `{{obj_id}}`."
          },
          "response": []
        },
        {
          "name": "List Objectives",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/objectives/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "organizations", "{{org_id}}", "objectives", ""]
            },
            "description": "Lists all active (non-archived) objectives for the organization. Includes `progress_pct` for each objective (null if KR weights ≠ 100%)."
          },
          "response": []
        },
        {
          "name": "Get Objective Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/objectives/{{obj_id}}/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "organizations", "{{org_id}}", "objectives", "{{obj_id}}", ""]
            },
            "description": "Returns the full objective with all nested Key Results and weighted `progress_pct`."
          },
          "response": []
        },
        {
          "name": "Update Objective",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Increase ARR by 35%\",\n  \"priority\": \"high\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/objectives/{{obj_id}}/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "organizations", "{{org_id}}", "objectives", "{{obj_id}}", ""]
            },
            "description": "Partially updates an objective. Only the fields provided are changed. Archived objectives cannot be edited."
          },
          "response": []
        },
        {
          "name": "Delete Objective",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/objectives/{{obj_id}}/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "organizations", "{{org_id}}", "objectives", "{{obj_id}}", ""]
            },
            "description": "Permanently deletes an objective and all its Key Results. Admins can delete any objective; other users can only delete their own."
          },
          "response": []
        },
        {
          "name": "Submit Objective for Approval",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/objectives/{{obj_id}}/submit/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "organizations", "{{org_id}}", "objectives", "{{obj_id}}", "submit", ""]
            },
            "description": "Transitions objective from `draft` → `pending_approval`.\n\n**Prerequisite:** All Key Result weightages must sum to exactly 100% or this call returns HTTP 400."
          },
          "response": []
        },
        {
          "name": "Approve Objective",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/objectives/{{obj_id}}/approve/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "organizations", "{{org_id}}", "objectives", "{{obj_id}}", "approve", ""]
            },
            "description": "Transitions objective from `pending_approval` → `approved`.\n\n**Allowed roles:** `org_admin`, `team_lead`."
          },
          "response": []
        },
        {
          "name": "Reject Objective",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Scope is too broad. Please narrow to a single product area.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/objectives/{{obj_id}}/reject/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "organizations", "{{org_id}}", "objectives", "{{obj_id}}", "reject", ""]
            },
            "description": "Transitions objective from `pending_approval` → `rejected`. A `reason` is **required**.\n\n**Allowed roles:** `org_admin`, `team_lead`."
          },
          "response": []
        },
        {
          "name": "Archive Objective",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/objectives/{{obj_id}}/archive/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "organizations", "{{org_id}}", "objectives", "{{obj_id}}", "archive", ""]
            },
            "description": "Archives an objective. Archived objectives are excluded from the list view.\n\n**Allowed roles:** admins only."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Key Results",
      "description": "Key Results (KRs) belong to an Objective and track measurable progress.\n\n**Weightage rules:**\n- **Single create/update**: the running total of all sibling KRs including the new one must equal exactly **100%**. This means a single KR must be set to 100, or use Bulk Replace to define multiple KRs atomically.\n- **Bulk Replace**: send an array — the batch total must equal **100%**.\n- `progress_pct` on the parent Objective returns `null` until the total equals 100%.\n\n**RAG status** is auto-computed on every value update:\n- `not_started` → no history yet\n- `green` ≥ 100% progress\n- `amber` ≥ 80% progress\n- `red` < 80% progress",
      "item": [
        {
          "name": "Create Single KR (100% weightage)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.collectionVariables.set('kr_id', body.id);",
                  "    console.log('kr_id set:', body.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Monthly Recurring Revenue\",\n  \"metric_label\": \"MRR in USD\",\n  \"type\": \"currency\",\n  \"start_value\": 100000,\n  \"target_value\": 130000,\n  \"current_value\": 100000,\n  \"unit\": \"USD\",\n  \"owner_id\": 1,\n  \"due_date\": \"2026-09-30\",\n  \"weightage\": 100\n}"
            },
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/objectives/{{obj_id}}/key-results/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "organizations", "{{org_id}}", "objectives", "{{obj_id}}", "key-results", ""]
            },
            "description": "Creates a single Key Result. The cumulative total of all KR weightages for this objective **must equal exactly 100%** after this operation, or the request is rejected with HTTP 400.\n\nTo define 2+ KRs, use **Bulk Replace KRs** instead.\n\n**KR types:** `numeric`, `percentage`, `boolean`, `currency`\n\nThe new KR's `id` is saved to `{{kr_id}}`."
          },
          "response": []
        },
        {
          "name": "List Key Results",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/objectives/{{obj_id}}/key-results/",
              "host": ["{{base_url}}"],
              "path": ["zenko", "api", "v1", "organizations", "{{org_id}}", "objectives", "{{obj_id}}", "key-results", ""]
            },
            "description": "Returns all Key Results for the given objective."
          },
          "response": []
        },
        {
          "name": "Bulk Replace KRs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    if (Array.isArray(body) && body.length > 0) {",
                  "        pm.collectionVariables.set('kr_id', body[0].id);",
                  "        console.log('kr_id set to first KR:', body[0].id);",
                  "    }",
