            "description": "Lists all members of the organization along with their roles."
          },
          "response": []
        },
        {
          "name": "Get Member Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/zenko/api/v1/organizations/{{org_id}}/members/{{member_id}}/",
